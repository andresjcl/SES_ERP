                          <TextRuns>
                            <TextRun>
                              <Value>=Parameters!ValEfectivo.Value + Parameters!ValCheques.Value + Parameters!ValTarjetas.Value</Value>
                              <Style>
                                <FontFamily>Calibri</FontFamily>
                                <FontSize>7pt</FontSize>
                                <Format>0.00</Format>
                              </Style>
                            </TextRun>
