                            <TextRun>
                              <Value>= SUM(iif (Fields!resumenPago.Value = "EFECTIVO" OR Fields!resumenPago.Value = "CHEQUE" OR Fields!resumenPago.Value = "TARJETA" , CDec(Fields!doc_valor.Value),Cdec( 0)))</Value>
                              <Style>
                                <FontFamily>Calibri</FontFamily>
                                <FontSize>7pt</FontSize>
                                <Format>0.00</Format>
                              </Style>
                            </TextRun>
                          </TextRuns>
                          <Style>
                            <TextAlign>Right</TextAlign>
                          </Style>
                        </Paragraph>
                      </Paragraphs>
